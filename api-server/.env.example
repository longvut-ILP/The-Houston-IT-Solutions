# Copy to .env and fill in.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nail_salon
PORT=4000

# Payment provider. Use "mock" until Stripe is configured.
# PAYMENT_PROVIDER=mock | stripe
PAYMENT_PROVIDER=mock

# Stripe Connect (only needed when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Auth — set a long random string in production. Tokens are signed with this.
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=12h

# CORS — lock to your UI origin in production (default "*").
# CORS_ORIGIN=http://localhost:5173
